# =============================================================================
# SIGAPRO — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commit o .env com valores reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key_aqui

# -----------------------------------------------------------------------------
# Desenvolvimento local — identifica qual prefeitura usar em localhost
# Preencha pelo menos uma das três opções abaixo.
# Prioridade: ID > SLUG > NAME > primeira prefeitura cadastrada
# -----------------------------------------------------------------------------
VITE_DEV_MUNICIPALITY_ID=
VITE_DEV_MUNICIPALITY_SLUG=campolimpopaulista
VITE_DEV_MUNICIPALITY_NAME=Campo Limpo Paulista

# Forçar uso do Supabase remoto mesmo em localhost (opcional)
VITE_FORCE_REMOTE_AUTH=false
VITE_FORCE_REMOTE_STORE=false

# -----------------------------------------------------------------------------
# Domínio raiz da plataforma (subdomínios ficam abaixo dele)
# Exemplo: campolimpopaulista.sigapromunicipal.com.br
# -----------------------------------------------------------------------------
VITE_ROOT_DOMAIN=sigapromunicipal.com.br

# -----------------------------------------------------------------------------
# R2 — credenciais SERVER-SIDE (usadas apenas no Worker, nunca no frontend)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=sua_account_id
R2_ACCESS_KEY_ID=sua_access_key_id
R2_SECRET_ACCESS_KEY=sua_secret_access_key
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com

# Buckets (devem existir no painel da Cloudflare)
R2_BUCKET_LOGOS=sigapro-logos
R2_BUCKET_DOCUMENTOS=sigapro-documentos

# URL pública do bucket de logos (configure Custom Domain no R2 ou use o endpoint público)
# Exemplo: https://logos.sigapromunicipal.com.br
R2_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# R2 — apenas a URL pública é exposta ao frontend (sem credenciais)
# -----------------------------------------------------------------------------
VITE_R2_PUBLIC_BASE_URL=https://logos.sigapromunicipal.com.br
VITE_R2_BUCKET_LOGOS=sigapro-logos
VITE_R2_BUCKET_DOCUMENTOS=sigapro-documentos

# Base da API R2 (Worker/Server). Em produção, aponte para o endpoint público do Worker.
# Exemplo: https://r2-api.sigapromunicipal.com.br
VITE_R2_API_BASE=
